# ── Database ───────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string (required)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/ai-knowledge-base

# ── MongoDB Atlas Vector Search ────────────────────────────────────────────────
# Set to "true" once you have created the vector search index in Atlas UI
# See README.md → "Atlas Vector Search Setup" for step-by-step instructions
MONGODB_ATLAS_VECTOR_SEARCH=false
ATLAS_VECTOR_INDEX_NAME=chunk_vector_index

# ── AI APIs ────────────────────────────────────────────────────────────────────
# Google Gemini — used for text-embedding-004 (768-dim embeddings)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq — used for LLM inference (Llama 3.3 70B)
GROQ_API_KEY=your_groq_api_key_here

# ── Auth ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
